# ── Required ─────────────────────────────────────────────
GEMINI_API_KEY=                  # Google Gemini — video scout, video analysis, cartoon, script (https://aistudio.google.com/apikey)
SERPER_API_KEY=                  # Serper — video search (https://serper.dev)
FAL_KEY=                         # fal.ai — Kling 2.5 Turbo Pro video generation (https://fal.ai/dashboard/keys)
ELEVENLABS_API_KEY=              # ElevenLabs — character sound generation (https://elevenlabs.io)

# ── Optional (extra trend sources) ──────────────────────
PERPLEXITY_API_KEY=              # Perplexity — fallback trend detection (https://perplexity.ai)

# ── Optional (YouTube downloads) ───────────────────────
# YT_DLP_COOKIES=                # Path to cookies.txt (export from browser) — avoids "Sign in to confirm you're not a bot"
# YT_DLP_COOKIES_FROM_BROWSER=   # e.g. chrome or firefox — use browser cookies

# ── Optional (Context Layer Contract — host cabinet slots; see CONTEXT.md) ──
# All optional: unset => defaults resolve to THIS cabinet (instance #0).
# CABINET_CONTEXT_ROOT=         # Absolute path to the host cabinet root (default: this cabinet)
# CONTEXT_BRAND=                # BRAND & VOICE doc (default: brand/arbi-character.md)
# CONTEXT_AUDIENCE=             # AUDIENCE doc (default: growth/character-pipeline-content-icp.md)
# CONTEXT_CHARACTER_IMAGE=      # Character reference PNG (default: brand/arbi-character.png)
# CONTEXT_OUTRO=                # Branded outro clip appended to each video (absent => outro step skipped)
# CONTEXT_MUSIC_DIR=            # Music-bed directory mixed under the character voice (absent => no bg music)

# ── Optional (YouTube uploads) ─────────────────────────
# Upload is automatic once youtube_token.json exists (run setup_youtube_auth.py once).
# YOUTUBE_UPLOAD_ENABLED=       # Set to "false" to disable auto-upload
# YOUTUBE_PLAYLIST_ID=          # Channel playlist ID — every video is added to this playlist (get from playlist URL: youtube.com/playlist?list=PLxxxxxx)
